{
  "name": "wk2026-server",
  "version": "1.0.0",
  "description": "World Cup 2026 Prediction Game - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "ts-node src/utils/migrate.ts",
    "migrate:multievent": "ts-node src/utils/migrateMultiEvent.ts",
    "seed": "ts-node src/utils/seed.ts",
    "populate-matches": "ts-node src/utils/populateMatches.ts",
    "test": "npm run test:tiebreak && npm run test:bonus && npm run test:lock",
    "test:tiebreak": "ts-node src/tests/tieBreak.test.ts",
    "test:bonus": "ts-node src/tests/bonusScoring.test.ts",
    "test:lock": "ts-node src/tests/leaderboardLock.test.ts"
  },
  "keywords": [
    "world-cup",
    "predictions",
    "api"
  ],
  "author": "Your Company",
  "license": "PROPRIETARY",
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.0.9",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/validator": "^13.15.10",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "pg": "^8.17.2",
    "pg-hstore": "^2.3.4",
    "redis": "^5.10.0",
    "sequelize": "^6.37.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
